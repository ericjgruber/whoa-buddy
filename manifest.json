{
  "manifest_version": 3,
  "name": "Whoa Buddy",
  "version": "1.0.0",
  "description": "Gives a visual warning for production environments in Acquia.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png"
  },
  "content_scripts": [
    {
      "matches": ["https://cloud.acquia.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  }
}